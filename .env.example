# Copie ce fichier en ".env" (jamais commité) et renseigne les vraies valeurs.
# Mets EXACTEMENT les mêmes valeurs en local et chez l'hébergeur pour un
# site strictement identique.

# Clé API Anthropic
ANTHROPIC_API_KEY=

# Secret de signature des JWT — au moins 32 caractères aléatoires.
# Génère-en un : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Connexion PostgreSQL (base persistante gratuite, ex. Neon).
# Format : postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Optionnel : port d'écoute (l'hébergeur le fournit automatiquement).
# PORT=3000

# === OPTIONNEL — fonctionnalités INERTES tant que non renseignées ===========
# Aucune de ces variables n'est requise au démarrage : le serveur tourne
# normalement sans elles, les fonctionnalités concernées restent simplement
# désactivées (réponse propre, jamais de crash).

# --- Reset mot de passe par email (compte SMTP, ex. Brevo : 300 mails/j) ---
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM="PC Helper <no-reply@tondomaine.com>"

# --- Paiement Stripe (commence en mode TEST : clés sk_test_ / whsec_) ------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...        # ID du prix Pro (abonnement) dans Stripe
# APP_URL=https://assistant-pc.onrender.com   # URL publique (redirections/lien email)
