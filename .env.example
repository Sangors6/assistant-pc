# Copie ce fichier en ".env" (jamais commité) et renseigne les vraies valeurs.
# Mets EXACTEMENT les mêmes valeurs en local et chez l'hébergeur pour un
# site strictement identique.

# Clé API Anthropic
ANTHROPIC_API_KEY=

# Secret de signature des JWT — au moins 32 caractères aléatoires.
# Génère-en un : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Connexion PostgreSQL (base persistante gratuite, ex. Neon).
# Format : postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Optionnel : port d'écoute (l'hébergeur le fournit automatiquement).
# PORT=3000
