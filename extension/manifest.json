{
  "manifest_version": 3,
  "name": "PC Helper",
  "version": "1.4.0",
  "description": "Assistant PC Helper partout : chat flottant + lecture du vrai matériel (CPU, RAM, cœurs) pour le site PC Helper.",
  "permissions": ["system.cpu", "system.memory", "system.display", "storage"],
  "host_permissions": [
    "https://assistant-pc.onrender.com/*",
    "http://localhost/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Ouvrir PC Helper" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel/panel.html", "panel/panel.css", "panel/panel.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
